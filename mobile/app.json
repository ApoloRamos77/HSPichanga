{
  "expo": {
    "name": "ChapatuCancha",
    "slug": "hspichanga",
    "version": "1.0.0",
    "scheme": "hspichanga",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#051208"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adhsoftsport.hspichanga"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#051208"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.adhsoftsport.hspichanga",
      "versionCode": 1,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDummyKeyForGoogleMapsToPreventCrash"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "android": {
            "org.gradle.jvmargs": "-Xmx4096m -XX:MaxMetaspaceSize=1024m",
            "crunchPngs": false
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Se necesita acceso a la galería para subir las fotos de las canchas.",
          "cameraPermission": "Se necesita acceso a la cámara para tomar fotos de las canchas."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Se necesita acceso a tu ubicación para configurar las coordenadas de tu cancha."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fe270916-493a-4681-8ae3-a08748f9dab2"
      }
    }
  }
}
